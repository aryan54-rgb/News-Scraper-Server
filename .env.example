# =============================================================================
# Kumbh Monitor Intelligence Platform - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values.
# Never commit the .env file to version control.
# =============================================================================

# --- Application ---
APP_NAME=kumbh-monitor
APP_VERSION=0.1.0
APP_ENV=development          # development | staging | production | testing
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=DEBUG          # DEBUG | INFO | WARNING | ERROR | CRITICAL
APP_CONNECT_EXTERNAL_SERVICES=true
APP_CORS_ALLOW_CREDENTIALS=true

# --- Database (PostgreSQL) ---
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=kumbh
DATABASE_PASSWORD=changeme_in_production
DATABASE_NAME=kumbh_monitor
DATABASE_ECHO=false          # Set true to log SQL queries in development only
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=1800

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_MAX_CONNECTIONS=50
REDIS_HEALTH_CHECK_INTERVAL=30

# --- Security ---
SECRET_KEY=replace-with-a-real-secret-key-in-production
API_KEY_HEADER=X-API-Key

# --- AI / OpenRouter (Future) ---
# OPENROUTER_API_KEY=
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- Object Storage (Future) ---
# S3_ENDPOINT_URL=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_BUCKET_RAW=kumbh-raw-content
# S3_BUCKET_MEDIA=kumbh-media

# --- CORS (comma-separated origins) ---
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# --- Testing overrides ---
# APP_ENV=testing
# APP_DEBUG=false
# APP_CONNECT_EXTERNAL_SERVICES=false
# DATABASE_NAME=kumbh_monitor_test
# REDIS_DB=1
